---
interface Post {
  id: string;
  data: {
    title: string;
    date: string;
    description?: string;
    tags?: string[];
  };
}

interface Props {
  posts: Post[];
  basePath: string;
}

const { posts, basePath } = Astro.props;

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<ul class="post-list">
  {sortedPosts.map((post) => {
    const date = new Date(post.data.date);
    const formatted = date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
    
    return (
      <li>
        <a href={`${basePath}/${post.id}`}>
          <time datetime={post.data.date}>{formatted}</time>
          <span class="title">{post.data.title}</span>
        </a>
        {post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </li>
    );
  })}
</ul>

<style>
  .post-list {
    list-style: none;
    padding: 0;
  }

  li {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  li:last-child {
    border-bottom: none;
  }

  a {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    color: var(--color-text);
    text-decoration: none;
  }

  a:hover .title {
    color: var(--color-accent);
  }

  time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .title {
    font-weight: 500;
    transition: color 0.2s;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    margin-left: calc(85px + 1rem); /* Align with title */
  }

  .tag {
    background: var(--color-code-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    a {
      flex-direction: column;
      gap: 0.25rem;
    }

    .tags {
      margin-left: 0;
    }
  }
</style>
